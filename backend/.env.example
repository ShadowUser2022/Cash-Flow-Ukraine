# Файл налаштувань для Cashflow Online Backend

# Порт сервера
PORT=3001

# URL MongoDB бази даних
MONGODB_URI=mongodb://localhost:27017/cashflow

# URL frontend додатку (для CORS)
FRONTEND_URL=http://localhost:5173

# Налаштування для production
NODE_ENV=development

# Секретний ключ для JWT (якщо буде потрібен)
JWT_SECRET=your-secret-key-here

# Налаштування для WebRTC STUN/TURN серверів
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# Логування
LOG_LEVEL=info

# Game Configuration
MAX_PLAYERS_PER_ROOM=6
GAME_TIMEOUT_MINUTES=120
DEAL_REFRESH_INTERVAL_MINUTES=10

# WebRTC TURN Server (optional)
TURN_SERVER_URL=
TURN_USERNAME=
TURN_PASSWORD=
